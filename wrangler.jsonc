{
  "name": "chameleon-finance",
  "pages_build_output_dir": "dist",
  "compatibility_date": "2025-12-12",
  "analytics_engine_datasets": [
    {
      "binding": "ANALYTICS",
      "dataset": "subgrid_events"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2_BUCKET",
      "bucket_name": "subgrid-storage"
    }
  ],
  "d1_databases": [
    {
      "binding": "USER_DB",
      "database_name": "chameleon-finance-db",
      "database_id": "5c279de4-9b53-455c-af95-6ca173b42d4f"
    }
  ]
}
